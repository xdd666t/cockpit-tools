      "changelog": [
        {
          "version": "0.26.8",
          "date": "2026-06-30",
          "notes": [
            "Adds immutable platform package version history metadata so users can install, reinstall, update, or roll back to published package versions.",
            "Refreshes the platform package artifact for the main channel without replacing any previously published zip."
          ],
          "locales": {
            "zh-CN": {
              "notes": [
                "新增不可变的平台包版本历史元数据，用户可以安装、重新安装、更新或回退到已发布的平台包版本。",
                "刷新主通道平台包产物，同时不替换任何已发布过的旧 zip。"
              ]
            },
            "zh-TW": {
              "notes": [
                "新增不可變的平台包版本歷史中繼資料，使用者可以安裝、重新安裝、更新或回復到已發布的平台包版本。",
                "刷新主通道平台包產物，同時不替換任何已發布過的舊 zip。"
              ]
            }
          }
        },
        {
          "version": "0.26.7",
          "date": "2026-06-22",
          "notes": [
            "Zed account overview, tabs, runtime controls, and page interactions are now supplied by the Zed platform package UI runtime.",
            "Core Shell keeps the platform package lifecycle controls while Zed page UI changes can ship through Zed package updates."
          ]
        },
        {
          "version": "0.26.6",
          "date": "2026-06-22",
          "notes": [
            "Zed platform package uses a sidecar adapter boundary for accounts, OAuth, switching, quota, and runtime commands.",
            "Platform package lifecycle supports independent install, update, uninstall, size display, and runtime readiness checks."
          ]
        }
      ],
